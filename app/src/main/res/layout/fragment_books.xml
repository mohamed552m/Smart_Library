<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/canvas_bg">
  <View android:layout_width="match_parent" android:layout_height="205dp" android:background="@drawable/bg_screen_header" />
  <View android:layout_width="128dp" android:layout_height="6dp" android:layout_gravity="top|center_horizontal" android:layout_marginTop="10dp" android:background="@drawable/bg_chip_dark" />
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="40dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="20dp">
    <TextView android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_header_icon" android:gravity="center" android:text="←" android:textColor="@color/white" android:textSize="22sp" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/explore" android:textColor="#99FFFFFF" android:textSize="14sp" />
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/books" android:textColor="@color/white" android:textSize="24sp" android:textStyle="bold" />
    </LinearLayout>
    <View android:layout_width="44dp" android:layout_height="44dp" />
  </LinearLayout>
  <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="112dp" android:clipToPadding="false" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="24dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_soft_panel_28" android:elevation="1dp" android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card_white_18" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingTop="12dp" android:paddingEnd="16dp" android:paddingBottom="12dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔎" android:textColor="@color/slate_400" android:textSize="16sp" />
          <EditText android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:background="@android:color/transparent" android:hint="@string/search_books_authors_topics" android:inputType="text" android:padding="0dp" android:textColor="@color/slate_900" android:textColorHint="@color/slate_400" android:textSize="15sp" />
        </LinearLayout>
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:overScrollMode="never" android:scrollbars="none">
          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_chip_dark" android:paddingHorizontal="16dp" android:paddingVertical="10dp" android:text="All" android:textColor="@color/white" android:textSize="14sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_chip_white" android:paddingHorizontal="16dp" android:paddingVertical="10dp" android:text="Popular" android:textColor="@color/slate_600" android:textSize="14sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_chip_white" android:paddingHorizontal="16dp" android:paddingVertical="10dp" android:text="New" android:textColor="@color/slate_600" android:textSize="14sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_chip_white" android:paddingHorizontal="16dp" android:paddingVertical="10dp" android:text="Available" android:textColor="@color/slate_600" android:textSize="14sp" />
          </LinearLayout>
        </HorizontalScrollView>
      </LinearLayout>
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/library_books" android:textColor="@color/slate_900" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/filter" android:textColor="@color/slate_500" android:textSize="14sp" />
      </LinearLayout>
      <LinearLayout android:id="@+id/booksContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" />
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</FrameLayout>