<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartLibraryCanvas" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/slate_900</item>
        <item name="colorPrimaryVariant">@color/slate_900</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/slate_900</item>
        <item name="android:windowBackground">@color/canvas_bg</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.SmartLibraryCanvas.BottomSheet</item>
    </style>

    <style name="ThemeOverlay.SmartLibraryCanvas.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.SmartLibraryCanvas.BottomSheet</item>
    </style>

    <style name="Widget.SmartLibraryCanvas.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>
